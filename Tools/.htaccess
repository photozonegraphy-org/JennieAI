# Place this as .htaccess inside your /Tools/ folder on the CDN server
# (rename this file to .htaccess when uploading)
# This adds CORS headers so the browser can fetch JS files from any origin

<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, OPTIONS"
    Header set Cache-Control "public, max-age=3600"
</IfModule>

<FilesMatch "\.js$">
    Header set Content-Type "application/javascript"
</FilesMatch>
