# Cloudflare Pages / CDN CORS headers
# Place this file at the root of your ai.photozonegraphy.com deployment
# This tells browsers it is OK to fetch the JS files from another domain

/Tools/*
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, OPTIONS
  Access-Control-Max-Age: 86400
  Cache-Control: public, max-age=3600
  X-Content-Type-Options: nosniff
